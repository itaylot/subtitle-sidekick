# העתק ל-.env וערוך.  cp .env.example .env

# הדומיין שמצביע על השרת (רשומת A → IP של השרת). חובה ל-TLS אוטומטי.
DOMAIN=stt.example.com

# מודל וחומרה (אופציונלי). ברירת המחדל = מודל עברי מדויק על CPU.
# למחשב חלש: MHS_MODEL=small . ל-GPU: MHS_DEVICE=cuda + MHS_COMPUTE=float16
MHS_MODEL=ivrit-ai/whisper-large-v3-turbo-ct2
MHS_DEVICE=cpu
MHS_COMPUTE=int8
MHS_LANG=he
